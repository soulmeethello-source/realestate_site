# 공공데이터포털 / vWorld API 키 설정 양식 (커밋용 — 실제 키는 .env 에 입력)
#
# 사용법:
#   1) 이 파일을 복사해 .env 로 만들기:  cp .env.example .env
#   2) .env 의 각 KEY= 뒤에 발급받은 키 붙여넣기
#   3) node proxy/server.js 로 프록시 실행
#
# ⚠️ .env 는 절대 커밋하지 마세요 (.gitignore 에 등록됨)

# 국토교통부 실거래가 (매매/전월세) — data.go.kr (Encoding 키 권장)
MOLIT_API_KEY=발급받은_서비스키_여기에
PROXY_PORT=8787

# vWorld 공동주택 공시가격 (NED 부동산 속성조회)
#  - vWorld 발급 시 활용 URL(도메인)을 등록해야 하고, 호출 때 domain 파라미터가 등록값과 일치해야 함
#  - 운영 도메인 estate.lifetiming.kr 로 등록 (로컬도 같은 domain 으로 서버에서 호출하므로 동작)
VWORLD_API_KEY=발급받은_vworld_키_여기에
# 등록 도메인이 다르면 아래 주석 해제 후 수정 (기본값: estate.lifetiming.kr)
# VWORLD_DOMAIN=estate.lifetiming.kr
